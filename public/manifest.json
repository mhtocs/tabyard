{
  "manifest_version": 3,
  "name": "tabyard",
  "version": "0.0.1",
  "description": "deterministic browser tab lifecycle automation",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "ui/popup/index.html",
    "default_title": "tabyard"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
