{
  "manifest_version": 3,
  "name": "tabcleaner",
  "version": "0.0.1",
  "description": "close idle tabs from plain-text rules, restore from graveyard",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "tabcleaner"
  }
}
